{
  "name": "harmonic-daw",
  "version": "0.1.0",
  "private": true,
  "description": "Harmonic — AI-native digital audio workstation",
  "workspaces": [
    "app",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=app",
    "build": "npm run build --workspace=shared && npm run build --workspace=app",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "engine:configure": "cd engine && cmake -B build -DCMAKE_BUILD_TYPE=Release",
    "engine:build": "cd engine && cmake --build build --config Release -j$(nproc)",
    "engine:clean": "rm -rf engine/build"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0"
  }
}
