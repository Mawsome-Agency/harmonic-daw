{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@harmonic/shared": ["../shared/src"]
    }
  },
  "include": ["src/renderer/**/*"],
  "exclude": ["node_modules", "dist", "src/main", "src/preload"]
}
